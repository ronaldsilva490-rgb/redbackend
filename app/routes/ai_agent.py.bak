        "description": "Alta qualidade, muito capaz para código",
        "pricing_tier": "GRÁTIS",
        "is_recommended": True,
        "best_for": "Análise e modificação de código"
    },
    "mistralai/mistral-7b-instruct": {
        "name": "Mistral 7B",
        "description": "Rápido e preciso",
